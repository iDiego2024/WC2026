rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // User Rules
    function isValidUser(data) {
      return data.keys().hasAll(['email', 'score', 'createdAt']) &&
             data.email is string && data.email.size() <= 200 &&
             data.score is number &&
             data.createdAt == request.time;
    }
    
    function isValidUserUpdate(data, old) {
       return data.keys().hasAll(['email', 'score', 'createdAt']) &&
              data.email == old.email &&
              data.createdAt == old.createdAt &&
              data.score is number;
    }

    match /users/{userId} {
      allow read: if true; // Public profiles for league rankings
      allow create: if isSignedIn() && request.auth.uid == userId && isValidId(userId) && isValidUser(incoming());
      allow update: if isSignedIn() && request.auth.uid == userId && isValidId(userId) && isValidUserUpdate(incoming(), existing());
    }

    // Prediction Rules
    function isValidPrediction(data) {
       return data.keys().hasAll(['userId', 'matchId', 'homeScore', 'awayScore', 'updatedAt']) &&
              data.userId == request.auth.uid &&
              data.matchId is string && data.matchId.size() <= 50 &&
              data.homeScore is number && data.homeScore >= 0 && data.homeScore <= 50 &&
              data.awayScore is number && data.awayScore >= 0 && data.awayScore <= 50 &&
              data.updatedAt == request.time;
    }

    match /predictions/{predictionId} {
       allow read: if true; // Allows seeing friends predictions
       allow create: if isSignedIn() && isValidId(predictionId) && isValidPrediction(incoming());
       allow update: if isSignedIn() && existing().userId == request.auth.uid && isValidId(predictionId) && isValidPrediction(incoming());
       allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    // League Rules
    function isValidLeague(data) {
       return data.keys().hasAll(['name', 'ownerId', 'inviteCode', 'members', 'createdAt']) &&
              data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
              data.ownerId == request.auth.uid &&
              data.inviteCode is string && data.inviteCode.size() <= 20 &&
              data.members is list && data.members.size() > 0 && data.members.size() <= 100 &&
              data.members[0] == request.auth.uid &&
              data.createdAt == request.time;
    }
    
    match /leagues/{leagueId} {
       allow read: if true; // Needed for invite functionality
       allow create: if isSignedIn() && isValidId(leagueId) && isValidLeague(incoming());
       allow update: if isSignedIn() && existing().ownerId == request.auth.uid; // Simplified for owner updates
       allow delete: if isSignedIn() && existing().ownerId == request.auth.uid;
    }
  }
}
