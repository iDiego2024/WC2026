{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and score",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "score": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "score", "createdAt"]
    },
    "Prediction": {
      "title": "Prediction",
      "description": "User's prediction for a match",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "matchId": { "type": "string" },
        "homeScore": { "type": "number" },
        "awayScore": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "matchId", "homeScore", "awayScore", "updatedAt"]
    },
    "League": {
      "title": "League",
      "description": "Private league for predicting with friends",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "ownerId": { "type": "string" },
        "inviteCode": { "type": "string" },
        "members": {
          "type": "array",
          "items": { "type": "string" }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "ownerId", "inviteCode", "members", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/predictions/{predictionId}": {
      "schema": { "$ref": "#/entities/Prediction" },
      "description": "Match predictions"
    },
    "/leagues/{leagueId}": {
      "schema": { "$ref": "#/entities/League" },
      "description": "Private friend leagues"
    }
  }
}
